// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Dish {
  id            String     @id @default(uuid())
  nameRu        String
  nameEn        String
  descriptionRu String
  descriptionEn String
  price         Int
  images        String[]
  categoryId    String
  category      Category   @relation(fields: [categoryId], references: [id])
  tags          Tag[]      @relation("DishTags")
  allergens     Allergen[] @relation("DishAllergens")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          Role           @default(USER)
  refreshTokens RefreshToken[]
  reservations  Reservation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum Role {
  USER
  ADMIN
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(uuid())
  slug      String   @unique
  nameRu    String
  nameEn    String
  dishes    Dish[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id     String @id @default(uuid())
  slug   String @unique
  nameRu String
  nameEn String
  dishes Dish[] @relation("DishTags")
}

model Allergen {
  id     String @id @default(uuid())
  slug   String @unique
  nameRu String
  nameEn String
  dishes Dish[] @relation("DishAllergens")
}

model Zone {
  id           String  @id @default(uuid())
  slug         String  @unique
  nameRu       String
  nameEn       String
  pricePerHour Int
  tables       Table[]
}

model Table {
  id           String        @id @default(uuid())
  number       Int           @unique
  zoneId       String
  zone         Zone          @relation(fields: [zoneId], references: [id])
  capacity     Int
  x            Int
  y            Int
  isActive     Boolean       @default(true)
  reservations Reservation[]
}

model Reservation {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  tableId     String
  table       Table             @relation(fields: [tableId], references: [id])
  startsAt    DateTime
  endsAt      DateTime
  guests      Int
  status      ReservationStatus @default(DRAFT)
  totalAmount Int               @default(0)
  items       OrderItem[]
  payment     Payment?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model OrderItem {
  id            String        @id @default(uuid())
  reservationId String
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  type          OrderItemType
  dishId        String?
  titleRu       String
  titleEn       String
  unitPrice     Int
  quantity      Int           @default(1)
}

model Payment {
  id                String        @id @default(uuid())
  reservationId     String        @unique
  reservation       Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  provider          String        @default("yookassa")
  providerPaymentId String?
  amount            Int
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

enum ReservationStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
}

enum OrderItemType {
  TIME
  DISH
  EXTRA
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
}